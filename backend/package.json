    "@types/node": "^18.15.11",
    "@types/sqlite3": "^3.1.8",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.1.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.4",
    "vitest": "^3.1.1"
